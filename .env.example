# Copy this file to .env and fill in real values.
# The .env file is gitignored — never commit it.

# ─────────────────────────────────────────────────────────────
# Anthropic API
# ─────────────────────────────────────────────────────────────
# Get key from https://console.anthropic.com/settings/keys
# Set a spend limit in the console BEFORE using (Settings → Limits)
ANTHROPIC_API_KEY=PUT_YOUR_KEY_HERE

# Use haiku during development (cheap), sonnet for demos
ANTHROPIC_MODEL=claude-haiku-4-5

# ─────────────────────────────────────────────────────────────
# Postgres credentials
# ─────────────────────────────────────────────────────────────
# Generate a real password with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# Then paste it into POSTGRES_PASSWORD below AND into DATABASE_URL.
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# DATABASE_URL is used by Python code running on your host (e.g. the ingest
# script from your venv). Host is 'localhost' because Docker maps the
# Postgres container's 5432 to your host's 5432.
#
# Inside the Docker network (api container → postgres container), the
# hostname is 'postgres' (the service name). docker-compose.yml overrides
# DATABASE_URL for the api service to use that form — you don't need to
# change anything here for that to work.
DATABASE_URL=postgresql://rag:REPLACE_ME_WITH_STRONG_PASSWORD@localhost:5432/rag

# ─────────────────────────────────────────────────────────────
# PubMed / NCBI E-utilities (for PubMed abstracts source)
# ─────────────────────────────────────────────────────────────
# Email is REQUIRED by NCBI policy — they block anonymous bulk traffic.
# Use a real email you check; NCBI may contact you about heavy usage.
NCBI_EMAIL=you@example.com

# API key is OPTIONAL but raises rate limit from 3 → 10 req/sec.
# Get one (free) at https://www.ncbi.nlm.nih.gov/account/settings/
# Leave blank to run without a key.
NCBI_API_KEY=

# ─────────────────────────────────────────────────────────────
# ICD-11 API (WHO)
# ─────────────────────────────────────────────────────────────
# Register at https://icd.who.int/icdapi (free) and create an API access key.
# You'll get a client_id and client_secret — paste both below.
# License: WHO ICD-API Terms of Service (non-commercial use OK with attribution).
ICD_CLIENT_ID=REPLACE_ME
ICD_CLIENT_SECRET=REPLACE_ME

# ─────────────────────────────────────────────────────────────
# Embedding model (do not change without re-ingesting all chunks)
# ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
EMBEDDING_DIM=768

# ─────────────────────────────────────────────────────────────
# Retrieval settings
# ─────────────────────────────────────────────────────────────
RETRIEVAL_K=5
RETRIEVAL_CANDIDATE_K=50
# Per-source retrieval: each retriever runs once per source with a source
# filter so no one source (e.g. PubMed's 10k docs) can crowd out the
# others in the candidate pool. PER_SOURCE_K is the top-k each sub-query
# returns; RRF unions them.
PER_SOURCE_K=20

# Reciprocal Rank Fusion: score = Σ 1/(HYBRID_RRF_K + rank). 60 is the
# Cormack/Vespa/OpenSearch default; lower values weight rank-1 more
# aggressively. Replaces the older weighted-sum-with-normalization scheme.
HYBRID_RRF_K=60

# Cross-encoder reranker. ms-marco-MiniLM-L-12-v2 is ~150ms/50 pairs on
# CPU. Swap to BAAI/bge-reranker-v2-m3 for higher quality at ~3x latency.
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# Refusal threshold on the cross-encoder score (log-odds-ish, roughly
# -10 to +10). If the top reranked chunk falls below this, the generation
# layer returns the canonical "insufficient evidence" refusal instead of
# attempting to answer. Tune on the eval set.
RERANK_MIN_SCORE=-5.0

# ─────────────────────────────────────────────────────────────
# CORS — origin(s) allowed to call the API
# ─────────────────────────────────────────────────────────────
# The UI is served by FastAPI itself at /ui so this defaults to same-origin.
# Comma-separated to allow more than one (e.g. localhost dev + production
# domain). Whitespace around commas is OK.
CORS_ORIGIN=http://localhost:8000,https://your-app.fly.dev

# ─────────────────────────────────────────────────────────────
# Logging — set to DEBUG locally, INFO or WARNING in "production" demo
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# /eval dashboard password (HTTP Basic, username ignored)
# ─────────────────────────────────────────────────────────────
# Protects the visual eval dashboard at /eval and its data endpoint
# /eval/data. Pick a short random string (no need for a user — the
# browser's Basic-Auth popup accepts any username).
#   python -c "import secrets; print(secrets.token_urlsafe(16))"
EVAL_PASSWORD=CHANGE_ME
